{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "ruby",
  "last-release-sha": "5694da60b08931ea260e13025689b8d8c47d767a",
  "packages": {
    ".": {
      "component": "kobako",
      "include-component-in-tag": false,
      "release-type": "ruby",
      "exclude-paths": ["wasm"]
    },
    "wasm/kobako-core": {
      "component": "kobako-core",
      "release-type": "rust",
      "release-as": "0.3.0",
      "extra-files": [
        {
          "type": "toml",
          "path": "/wasm/Cargo.lock",
          "jsonpath": "$.package[?(@.name=='kobako-core')].version"
        },
        {
          "type": "generic",
          "path": "/wasm/kobako-core/README.md"
        }
      ]
    },
    "wasm/kobako": {
      "component": "kobako-rs",
      "release-type": "rust",
      "release-as": "0.3.0",
      "extra-files": [
        {
          "type": "toml",
          "path": "/wasm/Cargo.lock",
          "jsonpath": "$.package[?(@.name=='kobako')].version"
        },
        {
          "type": "toml",
          "path": "/wasm/kobako/Cargo.toml",
          "jsonpath": "$.dependencies['kobako-core'].version"
        },
        {
          "type": "generic",
          "path": "/wasm/kobako/README.md"
        }
      ]
    },
    "wasm/kobako-io": {
      "component": "kobako-io",
      "release-type": "rust",
      "release-as": "0.3.0",
      "extra-files": [
        {
          "type": "toml",
          "path": "/wasm/Cargo.lock",
          "jsonpath": "$.package[?(@.name=='kobako-io')].version"
        },
        {
          "type": "generic",
          "path": "/wasm/kobako-io/README.md"
        }
      ]
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "kobako guest crates",
      "components": ["kobako-core", "kobako-rs", "kobako-io"]
    }
  ],
  "extra-files": [
    {
      "type": "toml",
      "path": "ext/kobako/Cargo.toml",
      "jsonpath": "$.package.version"
    },
    {
      "type": "toml",
      "path": "Cargo.lock",
      "jsonpath": "$.package[?(@.name=='kobako')].version"
    }
  ]
}
