{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-rubocop.sh",
            "statusMessage": "Rubocop auto-correct on the edited Ruby file"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-cargo-fmt.sh",
            "statusMessage": "cargo fmt on the edited Rust file"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-steep.sh",
            "statusMessage": "Steep type check (whole project)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-clippy.sh",
            "statusMessage": "cargo clippy -D warnings (host + crates + wasm + baker + wasm32 workspaces)"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-rustdoc.sh",
            "statusMessage": "cargo doc -D warnings (all workspaces, private items)"
          },
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && bundle exec rake >&2 || exit 2",
            "timeout": 1800,
            "statusMessage": "Running bundle exec rake (compile + test + rubocop + steep)"
          }
        ]
      }
    ]
  }
}
