# Build-time toolchain downloads (wasi-sdk, mruby tarballs); never committed.
/vendor/

# Pre-built Wasm guest binaries. Generated from wasm/ sources; the pure
# default is bundled into the released gem at publish time, the capability
# variants ship as downloadable Release assets. None are tracked in git.
/data/kobako.wasm
/data/kobako+regexp.wasm
/data/kobako+regexp-unicode.wasm
/data/kobako+json.wasm
/data/kobako+full.wasm

# rbs collection install destination. Regenerable from rbs_collection.lock.yaml
# via `bundle exec rbs collection install`; the lockfile is committed.
/.gem_rbs_collection/
