module Kobako
  module Catalog
    class Binding
      def initialize: (?handler: Kobako::Catalog::Handler) -> void

      def define: (Symbol | String name) -> Kobako::Namespace

      def lookup: (String target) -> untyped

      def encoded_preamble: () -> String

      def seal!: () -> self

      def sealed?: () -> bool
    end
  end
end
