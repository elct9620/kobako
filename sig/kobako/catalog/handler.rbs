module Kobako
  module Catalog
    class Handler
      def initialize: (?next_id: Integer) -> void

      def alloc: (untyped object) -> Kobako::Handle

      def fetch: (Integer id) -> untyped

      def reset!: () -> self

      def size: () -> Integer

      private

      def require_bound!: (Integer id) -> void
    end
  end
end
